# ============================================================
# 生产环境变量模板
# 1. 复制此文件为 .env
# 2. 填写所有待填项
# 3. 确认 .env 已在 .gitignore 中排除
# ============================================================

# ----- 服务器 -----
NODE_ENV=production
PORT=3001

# ----- 数据库（SQLite）-----
# SQLite 文件存放路径
DB_PATH=/home/ubuntu/class-pet-garden/server/data/class-pet-garden.db

# ----- JWT -----
# 生成方式：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=请在此填写64位随机字符串

# ----- 微信开放平台（UnionID 获取）-----
# 在 open.weixin.qq.com 注册开放平台账号后获取
WECHAT_OPEN_APP_ID=待填写
WECHAT_OPEN_APP_SECRET=待填写

# ----- 微信小程序 -----
# 在 mp.weixin.qq.com 注册小程序后获取
WECHAT_MINI_APP_ID=待填写
WECHAT_MINI_APP_SECRET=待填写

# ----- 微信支付（阶段D，备案后填写）-----
WECHAT_PAY_MCH_ID=待填写
WECHAT_PAY_API_KEY=待填写
WECHAT_PAY_NOTIFY_URL=https://YOUR_DOMAIN.com/api/payment/notify

# ----- 可选：MySQL（如需迁移时填写）-----
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=class_pet_garden
# MYSQL_PASSWORD=待填写
# MYSQL_DATABASE=class_pet_garden

# ----- 可选：Redis（如需启用时填写）-----
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=待填写
